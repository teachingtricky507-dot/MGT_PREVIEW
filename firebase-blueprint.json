{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A Jira project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "key": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "key", "ownerId"]
    },
    "Issue": {
      "title": "Issue",
      "description": "A task or issue within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["TODO", "IN_PROGRESS", "TESTING", "DONE"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "URGENT"] },
        "assigneeId": { "type": "string" },
        "reporterId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "order": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "status", "priority", "reporterId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on an issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "issueId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["issueId", "authorId", "content"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Log of project actions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "issueId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["ISSUE_CREATED", "STATUS_CHANGED", "ASSIGNEE_CHANGED", "COMMENT_ADDED"] },
        "oldValue": { "type": "string" },
        "newValue": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "userId", "type"]
    },
    "Message": {
      "title": "Message",
      "description": "Group chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "senderId", "content"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects"
    },
    "/projects/{projectId}/issues/{issueId}": {
      "schema": "Issue",
      "description": "Issues within a project"
    },
    "/projects/{projectId}/issues/{issueId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on issues"
    },
    "/projects/{projectId}/activities/{activityId}": {
      "schema": "Activity",
      "description": "Project activity logs"
    },
    "/projects/{projectId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Project group chat messages"
    }
  }
}
